# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/project_management

# JWT Configuration
SECRET_KEY=dev-secret-key-change-in-production-use-long-random-string-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API Configuration
API_V1_STR=/api/v1
PROJECT_NAME=Project Management API

# CORS Configuration
BACKEND_CORS_ORIGINS=["*"]

# Admin User (for initial setup)
FIRST_SUPERUSER_EMAIL=admin@example.com
FIRST_SUPERUSER_PASSWORD=changeme

# Email Configuration (mock for now)
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=noreply@example.com
